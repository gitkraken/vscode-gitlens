{
	"extends": "../../../tsconfig.base.json",
	"compilerOptions": {
		"jsx": "react",
		"lib": ["dom", "dom.iterable", "es2023"],
		"outDir": "../../../out/webviews",
		"paths": {
			"@env/*": ["../../env/browser/*"],
			"@gitlens/utils/*": ["../../../packages/utils/dist/*"],
			"@gitlens/git/*": ["../../../packages/git/dist/*"],
			"@gitlens/git-github/*": ["../../../packages/git-github/dist/*"]
		},
		"useDefineForClassFields": false // Needed for lit decorators https://github.com/lit/lit/issues/3278 https://lit.dev/docs/tools/publishing/#publishing-modern-javascript
	},
	"references": [
		{ "path": "../../../packages/utils" },
		{ "path": "../../../packages/git" },
		{ "path": "../../../packages/git-github" }
	],
	// Keep in sync with `src/eslint.config.mjs`
	"include": [
		"**/*",
		"../ipc/models/ipc.ts",
		"../**/protocol.ts",
		"../../**/models/**/*.ts",
		"../../**/utils/**/*.ts",
		"../../@types/**/*",
		"../../config.ts",
		"../../constants.ts",
		"../../constants.*.ts",
		"../../env/browser/**/*",
		"../../features.ts",
		"../../system/**/*.ts",
		"../../**/webview/**/*"
	],
	"exclude": ["../../**/-webview/**/*"]
}
