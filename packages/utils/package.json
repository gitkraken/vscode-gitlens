{
	"name": "@gitlens/utils",
	"version": "0.0.1",
	"private": true,
	"type": "module",
	"sideEffects": false,
	"imports": {
		"#env/*.js": {
			"node": {
				"types": "./dist/env/node/*.d.ts",
				"default": "./dist/env/node/*.js"
			},
			"default": {
				"types": "./dist/env/browser/*.d.ts",
				"default": "./dist/env/browser/*.js"
			}
		}
	},
	"exports": {
		"./__tests__/*.js": null,
		"./decorators/*.js": {
			"types": "./dist/decorators/*.d.ts",
			"default": "./dist/decorators/*.js"
		},
		"./env/browser/*.js": null,
		"./env/node/exec.js": {
			"types": "./dist/env/node/exec.d.ts",
			"default": "./dist/env/node/exec.js"
		},
		"./env/node/platform.js": {
			"types": "./dist/env/node/platform.d.ts",
			"default": "./dist/env/node/platform.js"
		},
		"./env/node/*.js": null,
		"./*.js": {
			"types": "./dist/*.d.ts",
			"default": "./dist/*.js"
		}
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "tsc -b",
		"clean": "pnpx rimraf --glob dist out **/tsconfig*.tsbuildinfo",
		"clean:all": "pnpm run clean && pnpm run clean:deps",
		"clean:deps": "pnpx rimraf --glob **/node_modules",
		"clean:lint": "pnpx rimraf --glob **/tsconfig*.tsbuildinfo",
		"test": "mocha --require tsx --ui tdd --timeout 30000 'src/**/__tests__/**/*.test.ts'"
	},
	"dependencies": {
		"fast-string-truncated-width": "catalog:",
		"vscode-uri": "catalog:"
	},
	"devDependencies": {
		"@types/mocha": "catalog:",
		"@types/sinon": "catalog:",
		"mocha": "catalog:",
		"sinon": "catalog:",
		"tinybench": "catalog:",
		"tsx": "catalog:",
		"typescript": "catalog:"
	}
}
