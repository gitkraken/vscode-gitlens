{
	"name": "@gitlens/git",
	"description": "GitLens Git package",
	"version": "0.0.1",
	"license": "SEE LICENSE IN LICENSE",
	"private": true,
	"type": "module",
	"sideEffects": false,
	"exports": {
		"./cache.js": {
			"types": "./dist/cache.d.ts",
			"default": "./dist/cache.js"
		},
		"./context.js": {
			"types": "./dist/context.d.ts",
			"default": "./dist/context.js"
		},
		"./errors.js": {
			"types": "./dist/errors.d.ts",
			"default": "./dist/errors.js"
		},
		"./features.js": {
			"types": "./dist/features.d.ts",
			"default": "./dist/features.js"
		},
		"./repositoryService.js": {
			"types": "./dist/repositoryService.d.ts",
			"default": "./dist/repositoryService.js"
		},
		"./run.types.js": {
			"types": "./dist/run.types.d.ts",
			"default": "./dist/run.types.js"
		},
		"./service.js": {
			"types": "./dist/service.d.ts",
			"default": "./dist/service.js"
		},
		"./models/*.js": {
			"types": "./dist/models/*.d.ts",
			"default": "./dist/models/*.js"
		},
		"./providers/*.js": {
			"types": "./dist/providers/*.d.ts",
			"default": "./dist/providers/*.js"
		},
		"./providers/shared/*.js": {
			"types": "./dist/providers/shared/*.d.ts",
			"default": "./dist/providers/shared/*.js"
		},
		"./utils/*.js": {
			"types": "./dist/utils/*.d.ts",
			"default": "./dist/utils/*.js"
		},
		"./remotes/*.js": {
			"types": "./dist/remotes/*.d.ts",
			"default": "./dist/remotes/*.js"
		},
		"./parsers/*.js": {
			"types": "./dist/parsers/*.d.ts",
			"default": "./dist/parsers/*.js"
		},
		"./watching/*.js": {
			"types": "./dist/watching/*.d.ts",
			"default": "./dist/watching/*.js"
		}
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "tsc -b",
		"clean": "pnpx rimraf --glob dist out **/tsconfig*.tsbuildinfo",
		"clean:all": "pnpm run clean && pnpm run clean:deps",
		"clean:deps": "pnpx rimraf --glob **/node_modules",
		"clean:lint": "pnpx rimraf --glob **/tsconfig*.tsbuildinfo",
		"test": "mocha --require tsx --ui tdd --timeout 30000 'src/**/__tests__/**/*.test.ts'"
	},
	"dependencies": {
		"@gitlens/utils": "workspace:*",
		"ignore": "catalog:"
	},
	"devDependencies": {
		"@types/mocha": "catalog:",
		"mocha": "catalog:",
		"tsx": "catalog:",
		"typescript": "catalog:",
		"vscode-uri": "catalog:"
	}
}
