{
	"name": "@gitlens/ipc",
	"description": "GitLens IPC package",
	"version": "0.0.1",
	"license": "SEE LICENSE IN LICENSE",
	"private": true,
	"type": "module",
	"sideEffects": false,
	"exports": {
		"./discovery.js": {
			"types": "./dist/discovery.d.ts",
			"default": "./dist/discovery.js"
		},
		"./ipcServer.js": {
			"types": "./dist/ipcServer.d.ts",
			"default": "./dist/ipcServer.js"
		}
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "tsc -b",
		"clean": "pnpx rimraf --glob dist out **/tsconfig*.tsbuildinfo",
		"clean:all": "pnpm run clean && pnpm run clean:deps",
		"clean:deps": "pnpx rimraf --glob **/node_modules",
		"clean:lint": "pnpx rimraf --glob **/tsconfig*.tsbuildinfo",
		"test": "mocha --require tsx --ui tdd --timeout 30000 'src/**/__tests__/**/*.test.ts'"
	},
	"dependencies": {
		"@gitlens/utils": "workspace:*"
	},
	"devDependencies": {
		"@types/mocha": "catalog:",
		"mocha": "catalog:",
		"tsx": "catalog:",
		"typescript": "catalog:"
	}
}
